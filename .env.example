# ----- Auth.js -----
# A random secret used to encrypt session cookies/JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# ----- Google OAuth (from Google Cloud Console > Credentials) -----
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----- Asana OAuth (from app.asana.com > Settings > Apps > Developer apps) -----
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# ----- App access control -----
# Allow anyone with a Google account on these domains (comma-separated).
ALLOWED_DOMAINS=lastmile.cafe
# Optional individual emails to allow in addition to the domains.
# If BOTH are empty, ALL sign-ins are denied (fail closed).
ALLOWED_EMAILS=

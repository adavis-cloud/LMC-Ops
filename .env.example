# ----- Auth.js -----
# A random secret used to encrypt session cookies/JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# ----- Google OAuth (from Google Cloud Console > Credentials) -----
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----- Asana OAuth (from app.asana.com > Settings > Apps > Developer apps) -----
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# ----- Square OAuth (from developer.squareup.com/apps > your app) -----
# SQUARE_ENV: "sandbox" (default, safe) or "production" (real invoices).
# Redirect URL to register on the app: <origin>/api/square/callback
SQUARE_ENV=sandbox
SQUARE_CLIENT_ID=
SQUARE_CLIENT_SECRET=

# ----- Slack app (from api.slack.com/apps > your app) — see SLACK-SETUP.md -----
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ----- Storage for Slack automation (Upstash Redis / Vercel KV) -----
# Needed so background Slack actions can read tokens + log activity.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ----- App access control -----
# Allow anyone with a Google account on these domains (comma-separated).
ALLOWED_DOMAINS=lastmile.cafe
# Optional individual emails to allow in addition to the domains.
# If BOTH are empty, ALL sign-ins are denied (fail closed).
ALLOWED_EMAILS=
